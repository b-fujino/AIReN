# データの読み込み
data <- read.csv("Evaluation_Results_timestamp20260226_234231.csv")
# データの確認
head(data)
# データの構造を確認
str(data)
data$Condition <- as.factor(data$Condition)
data$SCENARIO <- as.factor(data$SCENARIO)
# データの要約統計量を確認
summary(data)
#分散分析
anova_result <- aov(amount ~ Condition+Error(SCENARIO), data = data)
summary(anova_result)
# 条件ごとの平均と標準偏差を計算
library(dplyr)
summary_stats <- data %>%
group_by(Condition) %>%
summarise(
mean_score = mean(amount, na.rm = TRUE),
sd_score = sd(amount, na.rm = TRUE)
)
print(summary_stats)
# 条件ごとのスコアの分布を確認
library(ggplot2)
ggplot(data, aes(x = Condition, y = amount)) +
geom_boxplot() +geom_jitter(width = 0.2, alpha = 0.5, colos=SCENARIO) +
labs(title = "Score Distribution by Condition", x = "Condition", y = "Score")
# 条件ごとの平均と標準偏差を計算
library(dplyr)
summary_stats <- data %>%
group_by(Condition) %>%
summarise(
mean_score = mean(amount, na.rm = TRUE),
sd_score = sd(amount, na.rm = TRUE)
)
print(summary_stats)
# 条件ごとのスコアの分布を確認
library(ggplot2)
ggplot(data, aes(x = Condition, y = amount)) +
geom_boxplot() +geom_jitter(width = 0.2, alpha = 0.5, colos=data$SCENARIO) +
labs(title = "Score Distribution by Condition", x = "Condition", y = "Score")
# 条件ごとの平均と標準偏差を計算
library(dplyr)
summary_stats <- data %>%
group_by(Condition) %>%
summarise(
mean_score = mean(amount, na.rm = TRUE),
sd_score = sd(amount, na.rm = TRUE)
)
print(summary_stats)
# 条件ごとのスコアの分布を確認
library(ggplot2)
ggplot(data, aes(x = Condition, y = amount)) +
geom_boxplot() +geom_jitter(width = 0.2, alpha = 0.5, colors=data$SCENARIO) +
labs(title = "Score Distribution by Condition", x = "Condition", y = "Score")
# 条件ごとの平均と標準偏差を計算
library(dplyr)
summary_stats <- data %>%
group_by(Condition) %>%
summarise(
mean_score = mean(amount, na.rm = TRUE),
sd_score = sd(amount, na.rm = TRUE)
)
print(summary_stats)
# 条件ごとのスコアの分布を確認
library(ggplot2)
ggplot(data, aes(x = Condition, y = amount)) +
geom_boxplot() +geom_jitter(width = 0.2, alpha = 0.5, color=data$SCENARIO) +
labs(title = "Score Distribution by Condition", x = "Condition", y = "Score")
