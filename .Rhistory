# データの読み込み
data <- read.csv("Evaluation_Results_timestamp20260226_234231.csv")
# データの確認
head(data)
# データの構造を確認
str(data)
data$Condition <- as.factor(data$Condition)
# データの要約統計量を確認
summary(data)
# 条件ごとの平均と標準偏差を計算
library(dplyr)
summary_stats <- data %>%
group_by(Condition) %>%
summarise(
mean_score = mean(Score, na.rm = TRUE),
sd_score = sd(Score, na.rm = TRUE)
)
# 条件ごとの平均と標準偏差を計算
library(dplyr)
summary_stats <- data %>%
group_by(Condition) %>%
summarise(
mean_score = mean(amount, na.rm = TRUE),
sd_score = sd(amount, na.rm = TRUE)
)
print(summary_stats)
# 条件ごとのスコアの分布を確認
library(ggplot2)
ggplot(data, aes(x = Condition, y = Score)) +
geom_boxplot() +
labs(title = "Score Distribution by Condition", x = "Condition", y = "Score") +
theme_minimal()
