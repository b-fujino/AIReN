"{\n  \"報告者情報\": {\n    \"名前\": \"福井健太\",\n    \"年齢\": 43,\n    \"性別\": null,\n    \"職種\": \"トラック運転手\",\n    \"会社\": null,\n    \"勤続年数\": 12\n  },\n  \"インシデントの概要\": {\n    \"日付\": \"2023年10月1日\",\n    \"時刻\": \"午後4時30分頃\",\n    \"場所\": \"倉庫\",\n    \"概要\": \"倉庫での積荷作業中にニアミスが発生。リフターの位置に気づかず、バランスを崩して落下しそうになったが、荷台の縁を掴んで回避。\"\n  },\n  \"インシデント発生時の状況\": {\n    \"当人_L\": {\n      \"行動\": \"積荷作業担当。荷物をトラックの荷台に積み込む作業を担当。\",\n      \"見ていたもの\": null,\n      \"聴いていたこと\": null,\n      \"感情状態\": \"焦り、集中。時間通りに荷物を積み終え、次の配送先へ移動したいという気持ちが強く、集中力を欠いていた。\",\n      \"認知状態\": null,\n      \"身体状態\": \"腰痛、疲労感。腰痛があり、体調も優れなかった。特に腰の重さを感じていた。\",\n      \"受けていた指示\": \"特に指示はなかったが、顧客への配送という次の仕事に考えていた。\",\n      \"受け取っていた情報\": null\n    },\n    \"ソフトウェア_S\": null,\n    \"ハードウェア_H\": null,\n    \"物理環境_E\": null,\n    \"周囲の人_L\": {\n      \"同僚\": \"山田さん。隣で荷物を積んでいた。ニアミス直前に「そろそろ終わりかな」と話していた。\",\n      \"上司\": null,\n      \"顧客\": null,\n      \"その他\": \"ニアミス発生時に、特別な情報（アラーム、サイン、通知、同僚からの声かけ、倉庫内の注意喚起など）はなかった。\"\n    }\n  },\n  \"事象に至るまでの経緯\": \"今回のニアミスが発生する前に、福井さんは腰痛を感じており、作業姿勢に気を配っていた。しかし、荷物の重さと時間的なプレッシャーにより、十分な休憩を取ることができなかった。また、普段の業務において、時間的プレッシャーや集中力の低下、情報共有の不足、作業環境の騒音などが、ニアミスやヒヤリハットの要因として挙げられている。\",\n  \"背後要因\": {\n    \"業務\": null,\n    \"当人の心理\": null,\n    \"職場\": null,\n    \"組織\": {\n      \"訓練_研修\": null,\n      \"情報共有_情報開示\": \"経営戦略や将来計画に関する情報が不足している。\",\n      \"リスクマネジメント\": null,\n      \"意思決定\": null,\n      \"コミュニケーション\": \"部門間、そして現場と上層部間のコミュニケーションが不十分。\",\n      \"経営理念_経営方針\": \"経営理念や経営方針の理解度と業務への浸透度が低い。\"\n    }\n  },\n  \"普段と違った点\": \"普段の業務と異なり、今回のニアミス発生時には、時間的プレッシャーが強く、集中力が低下していた。また、体調も優れなかったため、腰痛や疲労感を感じていた。さらに、周囲の状況に注意を払う余裕がなく、リフターの位置に気づかなかった。\",\n  \"原因\": [\n    \"時間的プレッシャーと集中力の低下\",\n    \"情報共有の不足\",\n    \"作業環境の騒音\",\n    \"体調不良（腰痛、疲労感）\"\n  ],\n  \"類似事象\": [\n    \"過去にニアミスやヒヤリハットが発生している。\"\n  ],\n  \"対策\": [\n    \"リフターの位置確認の習慣化\",\n    \"作業中の集中力向上\",\n    \"体調管理の徹底（水分補給、暑さ対策）\",\n    \"無理をしない（体調不良時は上司や同僚に相談）\",\n    \"情報共有の改善（荷物の重量、配送ルートの変更など）\",\n    \"作業環境の改善（騒音対策、照明の改善）\"\n  ]\n}"