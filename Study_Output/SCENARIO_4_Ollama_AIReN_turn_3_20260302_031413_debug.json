"{\n  \"報告者情報\": {\n    \"名前\": \"Risa Minase\",\n    \"年齢\": null,\n    \"性別\": null,\n    \"職種\": \"インタビュー担当\",\n    \"会社\": null,\n    \"勤続年数\": null\n  },\n  \"インシデントの概要\": {\n    \"日付\": \"2024年1月18日\",\n    \"時刻\": null,\n    \"場所\": \"食品加工工場、ハンバーグ焼成工程\",\n    \"概要\": \"福井健太氏がハンバーグ焼成工程において、温度設定の確認を怠り、生焼けのハンバーグを製造したニアミスが発生。\"\n  },\n  \"インシデント発生時の状況\": {\n    \"当人_L\": {\n      \"行動\": \"前日の設定温度（150度）を覚えていたにも関わらず、温度表示の確認を怠り、作業を開始。\",\n      \"見ていたもの\": null,\n      \"聴いていたこと\": null,\n      \"感情状態\": null,\n      \"認知状態\": \"時間に追われる中で、周囲の作業員の声に気を取られ、温度表示の確認を忘れていた。\",\n      \"身体状態\": \"前日の夜勤明けで疲労はなかった。\",\n      \"受けていた指示\": null,\n      \"受け取っていた情報\": null\n    },\n    \"ソフトウェア_S\": null,\n    \"ハードウェア_H\": null,\n    \"物理環境_E\": null,\n    \"周囲の人_L\": {\n      \"同僚\": \"山田氏がコンベアベルトの緩み確認作業を行い、福井氏に注意喚起を行った。\",\n      \"上司\": null,\n      \"顧客\": null,\n      \"その他\": \"工場内は騒音レベルが高く、作業に集中しにくい状況だった。\"\n    }\n  },\n  \"事象に至るまでの経緯\": \"福井氏は、前日の設定温度を覚えていたため、温度表示の確認を省略し、作業を開始。作業中に他の作業員からの注意喚起があったものの、周囲の騒音に埋もれてしまい、十分に認識できなかった。結果、生焼けのハンバーグを製造してしまった。\",\n  \"背後要因\": {\n    \"業務\": {\n      \"難易度\": null,\n      \"責任の重さ\": null,\n      \"スケジュール\": null,\n      \"ワークロード\": null,\n      \"ハードウェア環境\": null,\n      \"物理的環境\": null,\n      \"ストレス\": \"繁忙期による時間的プレッシャーが、確認作業の精度を低下させた。\"\n    },\n    \"当人の心理\": null,\n    \"職場\": {\n      \"同僚\": null,\n      \"上司\": null,\n      \"職場の雰囲気\": \"騒音レベルが高く、集中しにくい環境だった。\"\n    },\n    \"組織\": {\n      \"訓練_研修\": null,\n      \"情報共有_情報開示\": \"山田氏からの注意喚起が、十分に伝わらなかった可能性がある。\",\n      \"リスクマネジメント\": \"温度表示の確認を省略した場合の注意喚起が、手順書に明記されていなかった。\",\n      \"意思決定\": null,\n      \"コミュニケーション\": null,\n      \"経営理念_経営方針\": null\n    }\n  },\n  \"普段と違った点\": \"普段とは異なる作業手順（温度表示の確認を省略）と、周囲の騒音により、注意喚起を十分に認識できなかったこと。\",\n  \"原因\": [\n    \"温度設定の確認を怠ったこと\",\n    \"温度表示の確認を省略したこと\",\n    \"周囲の注意喚起を十分に認識できなかったこと\",\n    \"時間に追われる中で作業を行ったこと\",\n    \"周囲の騒音に気を取られたこと\"\n  ],\n  \"類似事象\": [\n    \"過去に同様のニアミスが発生した事例はない。\"\n  ],\n  \"対策\": [\n    \"温度表示の確認を徹底する。\",\n    \"手順書に、温度表示の確認を省略した場合の注意喚起を明記する。\",\n    \"作業環境の騒音対策を行う。\",\n    \"作業時間を見直し、時間的プレッシャーを軽減する。\",\n    \"チームワークを強化し、情報共有を促進する。\"\n  ]\n}"