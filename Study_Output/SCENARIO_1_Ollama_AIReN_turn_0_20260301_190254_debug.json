"{\n  \"報告者情報\": {\n    \"名前\": \"福井健太\",\n    \"年齢\": 43,\n    \"性別\": null,\n    \"職種\": \"トラック運転手\",\n    \"会社\": null,\n    \"勤続年数\": 12\n  },\n  \"インシデントの概要\": {\n    \"日付\": \"2023年10月1日\",\n    \"時刻\": \"16時30分頃\",\n    \"場所\": \"倉庫\",\n    \"概要\": \"配送のための積荷作業中に、リフターから荷台へ降りる際、バランスを崩しそうになった。荷台の縁を掴んで回避した。\"\n  },\n  \"インシデント発生時の状況\": {\n    \"当人_L\": null,\n    \"ソフトウェア_S\": null,\n    \"ハードウェア_H\": null,\n    \"物理環境_E\": null,\n    \"周囲の人_L\": {\n      \"同僚\": \"田中氏\",\n      \"上司\": \"なし\",\n      \"顧客\": null,\n      \"その他\": null\n    }\n  },\n  \"事象に至るまでの経緯\": \"荷物を積み終え、配送の準備をしていた。スケジュールに遅れをとっているため、焦りを感じていた。リフターの位置と荷台の床の高低差に気づかず、バランスを崩した。\",\n  \"背後要因\": {\n    \"業務\": null,\n    \"当人の心理\": null,\n    \"職場\": null,\n    \"組織\": {\n      \"訓練_研修\": null,\n      \"情報共有_情報開示\": null,\n      \"リスクマネジメント\": \"体制は整っているが、対策の内容が抽象的で、従業員への周知が不十分。\",\n      \"意思決定\": null,\n      \"コミュニケーション\": \"上層部からの指示は明確だが、現場からの意見が伝わりにくく、一方的な情報伝達が多い。\",\n      \"経営理念_経営方針\": \"周知されているものの、十分な理解度や浸透度、具体性に欠ける。\"\n    }\n  },\n  \"普段と違った点\": \"当日、休憩なしで長時間労働のため疲労を感じていた。倉庫内は普段より騒がしく、集中しにくい状況だった。\",\n  \"原因\": [\n    \"リフターの位置の認識不足\",\n    \"疲労による集中力低下\",\n    \"スケジュールへの焦り\",\n    \"リフターと荷台の床の高低差の認識不足\",\n    \"周囲の状況への注意不足\"\n  ],\n  \"類似事象\": [\n    \"3年前、大型家具の配送作業中にリフターのベルトが緩み、家具が落下しそうになった。研修内容の理解不足、作業手順の遵守不足、安全意識の欠如が原因。\"\n  ],\n  \"対策\": [\n    \"リフター使用前に、位置と足元の空間を確認する。\",\n    \"荷物をバランス良く積む。\",\n    \"周囲の状況に注意し、ゆっくりと操作する。\",\n    \"リフターのベルトの張り具合を定期的に確認する。\",\n    \"疲労を感じたら、無理をせず休憩を取る。\"\n  ]\n}"