"{\n  \"報告者情報\": {\n    \"名前\": \"福井健太\",\n    \"年齢\": 41,\n    \"性別\": null,\n    \"職種\": \"ライン作業員\",\n    \"会社\": null,\n    \"勤続年数\": 10\n  },\n  \"インシデントの概要\": {\n    \"日付\": \"2024年1月18日\",\n    \"時刻\": \"午前9時頃\",\n    \"場所\": \"工場内の加熱調理ライン、ハンバーグの焼成工程\",\n    \"概要\": \"ハンバーグの焼成ラインで、機械の温度設定を誤り、180度設定すべきところを150度に設定してしまった。その結果、一部のハンバーグが生焼けになった。\"\n  },\n  \"インシデント発生時の状況\": {\n    \"当人_L\": null,\n    \"ソフトウェア_S\": null,\n    \"ハードウェア_H\": null,\n    \"物理環境_E\": null,\n    \"周囲の人_L\": {\n      \"同僚\": null,\n      \"上司\": null,\n      \"顧客\": null,\n      \"その他\": null\n    }\n  },\n  \"事象に至るまでの経緯\": \"朝のライン開始直後で、比較的忙しい時間帯だった。前日の夜勤担当者が設定した温度を確認し、ハンバーグをコンベアに流し込み、焼き加減を定期的に確認していた。しかし、他の担当者からの声かけで注意が散漫になり、温度表示の確認をいつもより早く行ってしまった。\",\n  \"背後要因\": {\n    \"業務\": null,\n    \"当人の心理\": null,\n    \"職場\": null,\n    \"組織\": {\n      \"訓練_研修\": null,\n      \"情報共有_情報開示\": \"重要情報は共有されているが、詳細な情報までは共有されていない場合がある。\",\n      \"リスクマネジメント\": null,\n      \"意思決定\": \"ある程度の透明性はあるものの、現場の意見反映に時間がかかる。\",\n      \"コミュニケーション\": \"上司と部下間のコミュニケーションは円滑だが、部署間のコミュニケーションは改善の余地がある。\",\n      \"経営理念_経営方針\": \"社内全体に浸透しているが、日々の業務に活かせる具体的な行動指針が不足している。\"\n    }\n  },\n  \"普段と違った点\": \"時間に追われるプレッシャーを感じていた。確認作業を省略してしまった。\",\n  \"原因\": [\n    \"温度設定の誤り\",\n    \"確認作業の省略\",\n    \"注意散漫\",\n    \"時間的なプレッシャー\"\n  ],\n  \"類似事象\": [\n    \"過去に設定ミスを経験したことがある。\"\n  ],\n  \"対策\": [\n    \"確認作業の省略を避ける\",\n    \"積極的に情報共有を行う\",\n    \"作業環境の改善\",\n    \"時間管理の徹底\"\n  ]\n}"