"{\n  \"報告者情報\": {\n    \"名前\": \"福井健太\",\n    \"年齢\": 35,\n    \"性別\": null,\n    \"職種\": \"電気工事士\",\n    \"会社\": null,\n    \"勤続年数\": 8\n  },\n  \"インシデントの概要\": {\n    \"日付\": \"2023年7月15日\",\n    \"時刻\": null,\n    \"場所\": \"工場内 A区画の動力分電盤前\",\n    \"概要\": \"新しい工作機械の配線作業中に、電源が切られていると思い込みゴム手袋を外しケーブルに触れた際、感電のような感覚を覚えたニアミス。\"\n  },\n  \"インシデント発生時の状況\": {\n    \"当人_L\": null,\n    \"ソフトウェア_S\": null,\n    \"ハードウェア_H\": null,\n    \"物理環境_E\": null,\n    \"周囲の人_L\": null\n  },\n  \"事象に至るまでの経緯\": \"上司から「全て遮断済み」という指示を受け、配線図を確認後、作業を開始。ゴム手袋を外した状態でケーブルに触れた。\",\n  \"背後要因\": {\n    \"業務\": null,\n    \"当人の心理\": null,\n    \"職場\": null,\n    \"組織\": {\n      \"訓練_研修\": null,\n      \"情報共有_情報開示\": null,\n      \"リスクマネジメント\": null,\n      \"意思決定\": \"上層部主導で一方通行になりがちで、現場の意見が反映されにくい。\",\n      \"コミュニケーション\": \"部門間の連携が不十分で、情報共有がスムーズに進まない。\",\n      \"経営理念_経営方針\": \"具体的な行動指針が示されていず、社員一人ひとりが理解し実践していくことに課題がある。\"\n    }\n  },\n  \"普段と違った点\": \"ニアミス発生時に、普段は周囲にいる電気工事士や設備管理担当者がいなかったこと。\",\n  \"原因\": [\n    \"確認不足（慣れた作業での確認省略、手順書への過信）\",\n    \"集中力の低下（長時間作業による集中力低下）\",\n    \"コミュニケーション不足（周囲の状況把握のための積極的なコミュニケーション不足）\",\n    \"心理的安全性の欠如（報告しにくい雰囲気）\",\n    \"過去の経験からの学びの不足（過去の事例共有・議論の不足）\"\n  ],\n  \"類似事象\": [\n    \"過去に工具が落下し、近くの作業員に当たりかけた経験がある。\"\n  ],\n  \"対策\": [\n    \"確認ステップの増加（上司の指示だけでなく、自身で遮断器の表示確認や電圧測定などを行う）\",\n    \"周囲の状況確認（他の作業員が周囲にいることを確認する）\",\n    \"作業前の確認（配線図と実際の配線箇所を再度確認する）\",\n    \"トレーニングの強化（日々の業務に必要な実践的なトレーニングを実施する）\",\n    \"リスク管理の強化（具体的なリスクアセスメントや軽減策の検討を行う）\",\n    \"情報共有の促進（情報共有の遅れを解消し、必要な情報にすぐにアクセスできるようにする）\",\n    \"心理的安全性の向上（報告しやすい雰囲気を作る）\",\n    \"過去の事例共有・議論の実施（過去の事例を共有し、同じミスを繰り返さないようにする）\"\n  ]\n}"