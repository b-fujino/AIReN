"{\n  \"報告者情報\": {\n    \"名前\": \"福井健太\",\n    \"年齢\": 43,\n    \"性別\": null,\n    \"職種\": \"トラック運転手\",\n    \"会社\": null,\n    \"勤続年数\": 12\n  },\n  \"インシデントの概要\": {\n    \"日付\": \"10月1日\",\n    \"時刻\": \"16:30頃\",\n    \"場所\": \"神奈川県横浜市港北区の工業団地内倉庫\",\n    \"概要\": \"トラックからの降車時にリフターに足を置こうとしたところ、バランスを崩して落ちそうになったニアミス。荷台の縁を掴んで落下は免れた。\"\n  },\n  \"インシデント発生時の状況\": {\n    \"当人_L\": null,\n    \"ソフトウェア_S\": null,\n    \"ハードウェア_H\": null,\n    \"物理環境_E\": null,\n    \"周囲の人_L\": {\n      \"同僚\": \"同僚との会話に気を取られていた。\",\n      \"上司\": \"特記事項なし\",\n      \"顧客\": null,\n      \"その他\": \"山田さん（親しい同僚）がニアミスを目撃し、声をかけた。\"\n    }\n  },\n  \"事象に至るまでの経緯\": \"同僚との会話、荷物配達の締め切りへの焦り、疲労、スケジュール遅延と急務などが複合的に影響した。\",\n  \"背後要因\": {\n    \"業務\": null,\n    \"当人の心理\": null,\n    \"職場\": null,\n    \"組織\": {\n      \"訓練_研修\": null,\n      \"情報共有_情報開示\": \"組織からの業務情報提供は全体的に機能しているが、迅速性、情報量、理解度向上の余地がある。\",\n      \"リスクマネジメント\": null,\n      \"意思決定\": \"意思決定プロセスに迅速性に課題がある。\",\n      \"コミュニケーション\": \"上層部と現場のコミュニケーションは円滑だが、現場からの意見反映に時間がかかる。\",\n      \"経営理念_経営方針\": \"浸透度は高いが、具体的な理解と行動への落とし込みが必要。\"\n    }\n  },\n  \"普段と違った点\": \"特別な指示、アラーム、サイン、通知などの特別な情報はなかった。\",\n  \"原因\": [\n    \"リフター使用前の位置確認の不足\",\n    \"同僚との連携の不足\",\n    \"リフターの固定工夫の不足\",\n    \"スケジュール遅延による焦り\",\n    \"疲労\",\n    \"作業手順の曖昧さ\",\n    \"周囲の状況への注意不足\",\n    \"リフターの形状\"\n  ],\n  \"類似事象\": [\n    \"過去に荷物の積み下ろし中に足を痛めた経験がある。\",\n    \"体調不良時に無理をせず報告する重要性を学んだ。\"\n  ],\n  \"対策\": [\n    \"作業前の確認事項の徹底（リフターの位置と高さ）\",\n    \"休憩時間の確保\",\n    \"同僚との連携強化\",\n    \"安全装備の充実（自動ブレーキ、車線逸脱警報など）\",\n    \"トレーニングの多様化\",\n    \"リスク管理の可視化\",\n    \"現場からの意見を迅速に上層部に伝えるための仕組み構築\",\n    \"経営理念や経営方針の理解と行動を促進する研修・啓発活動の強化\"\n  ]\n}"